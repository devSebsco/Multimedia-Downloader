# Server
PORT=3001
NODE_ENV=development

# CORS — the frontend URL that will make requests
FRONTEND_URL=http://localhost:4321

# Temporary download directory
TEMP_DIR=./temp

# Path to yt-dlp binary (leave as 'yt-dlp' if in PATH)
YTDLP_PATH=yt-dlp

# Path to FFmpeg binary (leave empty to use @ffmpeg-installer/ffmpeg bundled)
FFMPEG_PATH=

# Log level: debug | info | warn | error (default: debug in dev, info in production)
LOG_LEVEL=debug

# YouTube — proxy residencial (opcional, pero recomendado si Render IP está bloqueado)
# Formato: http://usuario:contraseña@host:puerto
# Los caracteres especiales en la contraseña (@ : / # ?) se codifican automáticamente.
YOUTUBE_PROXY_URL=

# YouTube — cookies FRESCAS (exportadas de incógnito SIN recargar la pestaña)
# Opcional, alternativa al proxy. Las cookies expiradas causan error "Sign in".
# Ruta absoluta al archivo cookies.txt en el servidor.
YOUTUBE_COOKIES_PATH=

# Instagram — proxy residencial OBLIGATORIO en producción (NO datacenter)
# Formato: http://usuario:contraseña@host:puerto
# Servicios recomendados: BrightData, Oxylabs, IPRoyal, Webshare (residencial)
# Los caracteres especiales en la contraseña (@ : / # ?) se codifican automáticamente.
INSTAGRAM_PROXY_URL=

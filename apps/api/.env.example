# Server
PORT=3001
NODE_ENV=development

# CORS — the frontend URL that will make requests
FRONTEND_URL=http://localhost:4321

# Temporary download directory
TEMP_DIR=./temp

# Path to yt-dlp binary (leave as 'yt-dlp' if in PATH)
YTDLP_PATH=yt-dlp

# Path to FFmpeg binary (leave empty to use @ffmpeg-installer/ffmpeg bundled)
FFMPEG_PATH=

# Log level: debug | info | warn | error (default: debug in dev, info in production)
LOG_LEVEL=debug

# NOTA: YOUTUBE_COOKIES_PATH e INSTAGRAM_COOKIES_PATH están DESHABILITADOS en el código.
# Las cookies expiradas empeoran la detección anti-bot desde IPs de datacenter.
# YouTube funciona sin cookies usando clientes android_vr/ios_downgraded.
# Instagram requiere proxy residencial en producción (NO datacenter).

# Instagram: URL completa del proxy residencial (OBLIGATORIO en producción)
# Formato: http://usuario:contraseña@host:puerto
# Servicios recomendados: BrightData, Oxylabs, IPRoyal (residential, no datacenter)
INSTAGRAM_PROXY_URL=

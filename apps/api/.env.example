PORT=3001
NODE_ENV=production
FRONTEND_URL=https://tu-frontend.vercel.app
TEMP_DIR=./temp
YTDLP_PATH=yt-dlp
LOG_LEVEL=info

# YouTube: ruta al archivo cookies.txt en formato Netscape
# Exportar desde Chrome con extensión "Get cookies.txt LOCALLY" (Export All)
# En Render: subir como Secret File y apuntar esta variable a esa ruta
YOUTUBE_COOKIES_PATH=/etc/secrets/youtube-cookies.txt

# Instagram: ruta al archivo cookies.txt en formato Netscape
# Exportar desde Chrome con extensión "Get cookies.txt LOCALLY" (Export All)
# En Render: subir como Secret File y apuntar esta variable a esa ruta
INSTAGRAM_COOKIES_PATH=/etc/secrets/instagram-cookies.txt
